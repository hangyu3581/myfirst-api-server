// ============================================================
// [Stage 흐름 및 Pod 배치]
//   1. Clone              : maven Pod  → PVC에 소스 클론
//   2. Build              : maven Pod  → PVC에서 빌드, target/*.jar 생성
//   3. Compute Image Meta : maven Pod  → 이미지 태그/경로 계산
//   4. Image Build & Push : kaniko Pod → PVC의 소스+jar로 이미지 빌드 후 Harbor 푸시
//   5. GitOps Update      : maven Pod  → PVC의 deploy.yaml 수정 후 gitops 브랜치 푸시
// ============================================================
pipeline {
  // stage별로 독립 Pod 사용 (PVC로 파일 공유)
  agent none

  environment {
    // === 사용자 수정 영역 ===
    GIT_URL                = 'https://github.com/himang10/myfirst-api-server.git'
    GIT_BRANCH             = 'master'
    GIT_ID                 = 'skala-github-id'
    IMAGE_NAME             = 'sk000-myfirst-api-server'
    // =======================
    IMAGE_TAG              = '1.0.0'
    IMAGE_REGISTRY_URL     = 'amdp-registry.skala-ai.com'
    IMAGE_REGISTRY_PROJECT = 'skala25a'
    DOCKER_CREDENTIAL_ID   = 'skala-image-registry-id'
    GITOPS_BRANCH          = 'gitops'
    GITOPS_MANIFEST        = 'k8s/deploy.yaml'
  }

  options {
    disableConcurrentBuilds()
    timestamps()
  }

  stages {

    // ── 1. 소스 클론 ── [maven Pod + PVC] ───────────────────────────────────────
    // ※ JENKINS-30600: git step은 container() 블록을 무시하고 항상 jnlp에서 실행됨
    //    → git config safe.directory도 jnlp에서 설정해야 함 (container 래퍼 제거)
    stage('Clone') {
      agent { label 'maven' }       // maven Pod 생성, PVC → /home/jenkins/agent
      steps {
        // ===== DEBUG:START =====
        sh '''
          echo "=== [DEBUG] Clone stage ==="
          echo "USER=$(id)"
          echo "WORKSPACE=${WORKSPACE}"
          git config --global --list | grep safe || echo "no safe.directory set yet"
          echo "--- PVC 마운트 확인 ---"
          df -h /home/jenkins/agent || true
        '''
        // ===== DEBUG:END =====
        // git step은 jnlp에서 실행되므로 safe.directory도 여기서 설정
        sh 'git config --global --add safe.directory "*"'
        git branch: "${GIT_BRANCH}",
            url: "${GIT_URL}",
            credentialsId: "${GIT_ID}"
        // ===== DEBUG:START =====
        sh 'echo "=== [DEBUG] Clone done."; ls -la; ls -la k8s/ || echo "k8s/ not found"'
        // ===== DEBUG:END =====
      }
    }

    // ── 2. Maven 빌드 ── [maven Pod + PVC] ───────────────────────────────────────
    stage('Build') {
      agent { label 'maven' }       // 새 maven Pod, PVC에서 소스 읽어 빌드
      steps {
        container('maven') {
          // ===== DEBUG:START =====
          sh '''
            echo "=== [DEBUG] Build stage ==="
            echo "mvn version: $(mvn -version 2>&1 | head -1)"
            ls -la || true
          '''
          // ===== DEBUG:END =====
          sh 'mvn clean package -DskipTests'
          // ===== DEBUG:START =====
          sh 'echo "=== [DEBUG] Build done."; ls -la target/*.jar 2>/dev/null || echo "no jar"'
          // ===== DEBUG:END =====
        }
      }
    }

    // ── 3. 이미지 태그 계산 ── [maven Pod + PVC] ──────────────────────────────────
    stage('Compute Image Meta') {
      agent { label 'maven' }       // maven Pod에서 태그 계산
      steps {
        container('maven') {
          script {
            def uuid = java.util.UUID.randomUUID().toString()
            env.FINAL_IMAGE_TAG = "${IMAGE_TAG}-${env.BUILD_NUMBER}-${uuid.substring(0,8)}"
            env.IMAGE_REGISTRY  = "${env.IMAGE_REGISTRY_URL}/${env.IMAGE_REGISTRY_PROJECT}"
            env.REG_HOST        = env.IMAGE_REGISTRY_URL
            env.IMAGE_REF       = "${env.IMAGE_REGISTRY}/${IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"
            echo "IMAGE_REF: ${env.IMAGE_REF}"
          }
        }
      }
    }

    // ── 4. 이미지 빌드 & 푸시 ── [kaniko Pod + PVC] ──────────────────────────────
    //      PVC에 있는 소스코드 + target/*.jar + Dockerfile을 kaniko Pod에서 직접 사용
    //      인증: Jenkins credential(skala-image-registry-id) → /kaniko/.docker/config.json 생성
    stage('Image Build & Push') {
      agent { label 'kaniko' }      // kaniko Pod 생성, PVC → /home/jenkins/agent
      steps {
        withCredentials([usernamePassword(
          credentialsId: "${DOCKER_CREDENTIAL_ID}",
          usernameVariable: 'REG_USER',
          passwordVariable: 'REG_PASS'
        )]) {
          container('kaniko') {
            // ===== DEBUG:START =====
            sh '''
              echo "=== [DEBUG] Image Build stage ==="
              echo "IMAGE_REF=${IMAGE_REF}"
              echo "IMAGE_REGISTRY_URL=${IMAGE_REGISTRY_URL}"
              echo "REG_USER=${REG_USER}"
              echo "WORKSPACE=${WORKSPACE}"
              echo "--- WORKSPACE 파일 확인 (Dockerfile, target/) ---"
              ls -la "${WORKSPACE}/Dockerfile" || echo "Dockerfile not found!"
              ls -la "${WORKSPACE}/target/"*.jar 2>/dev/null || echo "no jar"
            '''
            // ===== DEBUG:END =====
            sh '''
              set -eux

              # 인증: Jenkins credential(skala-image-registry-id)에서 가져온 username/password로 config.json 생성
              # kaniko는 DOCKER_CONFIG=/kaniko/.docker 의 config.json을 읽어 레지스트리 인증
              mkdir -p /kaniko/.docker
              AUTH=$(printf '%s:%s' "${REG_USER}" "${REG_PASS}" | base64 | tr -d '\n')
              cat > /kaniko/.docker/config.json << EOF
{"auths":{"${IMAGE_REGISTRY_URL}":{"auth":"${AUTH}"}}}
EOF

              /kaniko/executor \
                --dockerfile=Dockerfile \
                --context=dir://${WORKSPACE} \
                --destination="${IMAGE_REF}" \
                --force
              # --dockerfile=Dockerfile   : context 루트 기준 상대 경로
              # --context=dir://$WORKSPACE: PVC의 실제 소스 경로 (Jenkins가 설정한 workspace)
              # TLS 오류 발생 시 아래 옵션 추가:
              #   --skip-tls-verify-registry=${IMAGE_REGISTRY_URL}
            '''
          }
        }
      }
    }

    // ── 5. GitOps 업데이트 ── [maven Pod + PVC] ───────────────────────────────────
    //      PVC의 deploy.yaml 수정 후 gitops 브랜치에 강제 푸시 → ArgoCD 트리거
    stage('GitOps Update') {
      agent { label 'maven' }       // maven Pod, PVC에 있는 deploy.yaml 직접 수정
      steps {
        withCredentials([usernamePassword(
          credentialsId: "${GIT_ID}",
          usernameVariable: 'GIT_USER',
          passwordVariable: 'GIT_PASS'
        )]) {
          script {
            env.REPO_PATH = env.GIT_URL.replaceFirst(/^https?:\/\//, '')
          }
          sh '''
            set -eux
            git config --global user.name  "skala-gitops"
            git config --global user.email "skala@skala-ai.com"
            git config --global --add safe.directory '*'

            # 1. gitops 브랜치로 전환 (master 기준으로 신규 생성/초기화)
            git checkout -B "${GITOPS_BRANCH}"

            # 2. deploy.yaml 이미지 태그 업데이트
            IMAGE_BASE="${IMAGE_REF%:*}"
            sed -Ei "s|(image:[[:space:]]*)${IMAGE_BASE}:[^[:space:]]*|\\1${IMAGE_REF}|" "${GITOPS_MANIFEST}"

            # 3. 커밋 & 강제 푸시 (원격 gitops 브랜치를 현재 상태로 덮어씀)
            git add "${GITOPS_MANIFEST}"
            git commit -m "[AUTO] image: ${IMAGE_NAME}:${FINAL_IMAGE_TAG}"
            git remote set-url origin "https://${GIT_USER}:${GIT_PASS}@${REPO_PATH}"
            git push origin "${GITOPS_BRANCH}" --force
            echo "[DONE] gitops 브랜치 업데이트 완료: ${IMAGE_REF}"
          '''
        }
      }
    }

  } // stages

  post {
    always {
      // PVC 워크스페이스 정리: git clone, target/, 빌드 아티팩트 삭제
      // agent none 파이프라인은 post에 node() 블록이 필요
      node('maven') {
        sh '''
          echo "=== [CLEANUP] PVC 워크스페이스 정리 ==="
          echo "WORKSPACE=${WORKSPACE}"
          du -sh "${WORKSPACE}" 2>/dev/null || true
          # workspace 루트 자체는 유지 (rm -rf ${WORKSPACE} 하면 durable task 상태파일 손실)
          # * 글로브는 .jenkins* dotfile을 포함하지 않으므로 상태파일 자동 보존
          rm -rf "${WORKSPACE}"/* 2>/dev/null || true
          echo "=== [CLEANUP] 완료 ==="
        '''
      }
    }
    success {
      echo "CI 완료: ${env.IMAGE_REF} 빌드/푸시 및 gitops 브랜치 업데이트 완료"
    }
    failure {
      echo "파이프라인 실패. 로그를 확인하세요."
    }
  }
}
