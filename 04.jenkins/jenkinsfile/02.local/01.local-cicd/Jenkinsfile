pipeline {
  agent any

  environment {
    // === 사용자 수정 영역 ===
    GIT_URL                = 'https://github.com/himang10/myfirst-api-server.git'
    GIT_BRANCH             = 'master'            // 또는 main
    GIT_ID                 = 'skala-github-id'   // GitHub PAT credential ID
    IMAGE_NAME             = 'sk000-myfirst-api-server'    
    // =======================
    IMAGE_TAG              = '1.0.0'    
    IMAGE_REGISTRY_URL     = 'amdp-registry.skala-ai.com'
    IMAGE_REGISTRY_PROJECT = 'skala25a'

    DOCKER_CREDENTIAL_ID   = 'skala-image-registry-id'  // Harbor 인증 정보 ID
    K8S_NAMESPACE          = 'skala-practice'
  }

  options {
    disableConcurrentBuilds()
    timestamps()
  }

  stages {
    stage('Clone Repository') {
      steps {
        echo 'Clone Repository'
        git branch: "${GIT_BRANCH}", 
            url: "${GIT_URL}", 
            credentialsId: "${GIT_ID}"
        sh 'ls -al'
      }
    }

    stage('Build with Maven') {
      steps {
        echo 'Build with Maven'
        sh 'mvn clean package -DskipTests'
        sh 'ls -al'
      }
    }

    // 태그/이미지 경로 계산 (메타)
    stage('Compute Image Meta') {
      steps {
        script {
          env.FINAL_IMAGE_TAG = "${IMAGE_TAG}-${env.BUILD_NUMBER}"
          env.IMAGE_REGISTRY  = "${env.IMAGE_REGISTRY_URL}/${env.IMAGE_REGISTRY_PROJECT}"
          env.REG_HOST        = env.IMAGE_REGISTRY_URL
          env.IMAGE_REF       = "${env.IMAGE_REGISTRY}/${IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"

          echo "REG_HOST: ${env.REG_HOST}"
          echo "IMAGE_REF: ${env.IMAGE_REF}"
        }
      }
    }


    // 로그인/빌드/푸시/정리
    stage('Image Build & Push (docker)') {
        steps {
            script {
                docker.withRegistry("https://${IMAGE_REGISTRY}", "${DOCKER_CREDENTIAL_ID}") {
                    def appImage = docker.build("${IMAGE_REF}", "--platform=linux/amd64 .")
                    appImage.push()
                }
            }
        }
    }

    // k8s 매니페스트 이미지 태그 업데이트 ───────────────
    stage('Update K8s Manifests') {
      steps {
        sh '''
          set -eux
          test -f ./k8s/deploy.yaml

          # ===== DEBUG:START =====
          echo "=== [DEBUG] Update K8s Manifests stage ==="
          echo "IMAGE_REF=${IMAGE_REF}"
          echo "--- BEFORE ---"
          grep -n 'image:' ./k8s/deploy.yaml || true
          # ===== DEBUG:END =====

          IMAGE_BASE="${IMAGE_REF%:*}"
          sed -Ei "s|(image:[[:space:]]*)${IMAGE_BASE}:[^[:space:]]*|\\1${IMAGE_REF}|" ./k8s/deploy.yaml

          # ===== DEBUG:START =====
          echo "--- AFTER ---"
          grep -n 'image:' ./k8s/deploy.yaml || true
          # ===== DEBUG:END =====
        '''
      }
    }

    // ── Kubernetes 직접 배포 (kubectl apply) ───────────────
    stage('Deploy to Kubernetes') {
      steps {
        sh '''
          set -eux

          # ===== DEBUG:START =====
          echo "=== [DEBUG] Deploy to Kubernetes stage ==="
          echo "K8S_NAMESPACE=${K8S_NAMESPACE}"
          echo "IMAGE_NAME=${IMAGE_NAME}"
          kubectl version --client 2>&1 | head -1 || echo "kubectl not found!"
          # ===== DEBUG:END =====

          echo "=== k8s yaml 적용 ==="
          kubectl apply -n "${K8S_NAMESPACE}" -f ./k8s/

          echo "=== 배포 롤아웃 대기 ==="
          kubectl rollout status deployment/"${IMAGE_NAME}" \
            -n "${K8S_NAMESPACE}" \
            --timeout=180s

          echo "=== 배포 완료: ${IMAGE_REF} ==="
          kubectl get pods -n "${K8S_NAMESPACE}" -l "app=${IMAGE_NAME}"
        '''
      }
    }

  }

  post {
    always {
      deleteDir()  // 워크스페이스 정리 (git clone, target/, 빌드 아티팩트)
    }
  }
}

