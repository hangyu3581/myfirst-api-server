// ============================================================
// Jenkinsfile-CICD.kaniko
// k8s 배포 Jenkins (02.kubernetes/k8s) 전용 CI/CD 파이프라인
// ※ GitOps(ArgoCD) 없이 Jenkins가 직접 kubectl로 배포
//
// [CI 부분 변경 사항 vs jenkinsfile/04.k8s/Jenkinsfile-CI.k8s-kaniko]
//   - cloud: 'skala' → 'kubernetes'
//   - namespace: 'skala-practice' 명시
//   - jnlp 이미지: latest → latest-jdk21
//   - maven 이미지: 3.8.5-openjdk-17 → 3.9-eclipse-temurin-17
//   - kaniko secret 이름: 'harbor-registry-secret' → 'registry-credentials'
//
// [CD 부분] Git Push(gitops) 대신 kubectl 직접 배포
//   - kubectl 컨테이너 추가 (bitnami/kubectl)
//   - Jenkins 에이전트 Pod가 jenkins ServiceAccount로 실행
//   → in-cluster 인증 자동 적용 (별도 kubeconfig 불필요)
//
// [RBAC 요구 사항 - 직접 배포 시 01-rbac.yaml 업데이트 필요]
//   현재 ClusterRole(jenkins-master)에 아래 권한 추가 필요:
//   - apiGroups: ["apps"]
//     resources: ["deployments"]
//     verbs: ["create","update","patch","delete"]
//   - apiGroups: [""]
//     resources: ["services","configmaps"]
//     verbs: ["create","update","patch","delete"]
//
// [전제 조건]
//   - Jenkins Kubernetes 플러그인 설치
//   - k8s Secret 'registry-credentials' 생성 필요 (Harbor .dockerconfigjson):
//       kubectl create secret docker-registry registry-credentials \
//         --docker-server=amdp-registry.skala-ai.com \
//         --docker-username=<USER> --docker-password=<PASS> \
//         -n skala-practice
//   - Credentials:
//       skala-github-id: GitHub PAT (username/password)
//   - 소스 리포지토리에 ./k8s/ 디렉토리 (deploy.yaml 등) 및 Dockerfile 포함
// ============================================================
pipeline {
  agent {
    kubernetes {
      cloud 'kubernetes'                    // 03-configmap.yaml에 정의된 클라우드 이름
      namespace 'skala-practice'            // Jenkins가 배포된 네임스페이스
      yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins: cicd-kaniko
spec:
  restartPolicy: Never
  serviceAccountName: jenkins             # 01-rbac.yaml에서 생성한 ServiceAccount
  volumes:
    - name: ws
      emptyDir: {}
    - name: maven-cache
      emptyDir: {}
    - name: kaniko-secret
      secret:
        secretName: registry-credentials  # Harbor 인증 정보 (docker-registry type Secret)
        items:
          - key: .dockerconfigjson
            path: config.json
  containers:
    - name: jnlp
      image: jenkins/inbound-agent:latest-jdk21
      volumeMounts:
        - name: ws
          mountPath: /home/jenkins/agent

    - name: git
      image: alpine/git:latest
      command: ["sh","-c"]
      args: ["cat"]
      tty: true
      volumeMounts:
        - name: ws
          mountPath: /home/jenkins/agent

    - name: maven
      image: maven:3.9-eclipse-temurin-17
      command: ["sh","-c"]
      args: ["cat"]
      tty: true
      volumeMounts:
        - name: ws
          mountPath: /home/jenkins/agent
        - name: maven-cache
          mountPath: /root/.m2

    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ["/busybox/sh","-c"]
      args: ["cat"]
      tty: true
      env:
        - name: DOCKER_CONFIG
          value: /kaniko/.docker
      volumeMounts:
        - name: ws
          mountPath: /home/jenkins/agent
        - name: kaniko-secret
          mountPath: /kaniko/.docker
          readOnly: true

    - name: kubectl
      image: bitnami/kubectl:latest         # kubectl 실행 전용 컨테이너
      command: ["sh","-c"]
      args: ["cat"]
      tty: true
      securityContext:
        runAsUser: 0
      volumeMounts:
        - name: ws
          mountPath: /home/jenkins/agent
"""
    }
  }

  environment {
    // === 사용자 수정 영역 ===
    GIT_URL                = 'https://github.com/himang10/myfirst-api-server.git'
    GIT_BRANCH             = 'master'                   // 또는 main
    GIT_ID                 = 'skala-github-id'          // GitHub PAT Credential ID
    IMAGE_NAME             = 'sk000-myfirst-api-server' // Harbor 이미지 이름
    // =======================
    IMAGE_TAG              = '1.0.0'
    IMAGE_REGISTRY_URL     = 'amdp-registry.skala-ai.com'
    IMAGE_REGISTRY_PROJECT = 'skala25a'
    K8S_NAMESPACE          = 'skala-practice'
  }

  options {
    disableConcurrentBuilds()
    timestamps()
  }

  stages {

    // ── 1. 소스 클론 ──────────────────────────────────────────
    stage('Clone Repository') {
      steps {
        container('git') {
          dir("${env.WORKSPACE}") {
            git branch: "${GIT_BRANCH}",
                url: "${GIT_URL}",
                credentialsId: "${GIT_ID}"
          }
        }
      }
    }

    // ── 2. Maven 빌드 ─────────────────────────────────────────
    stage('Build with Maven') {
      steps {
        container('maven') {
          dir("${env.WORKSPACE}") {
            sh 'mvn clean package -DskipTests'
          }
        }
      }
    }

    // ── 3. 이미지 메타 계산 ───────────────────────────────────
    stage('Compute Image Meta') {
      steps {
        container('maven') {
          script {
            def hashcode = sh(script: "date +%s%N | sha256sum | cut -c1-12", returnStdout: true).trim()
            env.FINAL_IMAGE_TAG = "${IMAGE_TAG}-${hashcode}"
            env.IMAGE_REGISTRY  = "${env.IMAGE_REGISTRY_URL}/${env.IMAGE_REGISTRY_PROJECT}"
            env.REG_HOST        = env.IMAGE_REGISTRY_URL
            env.IMAGE_REF       = "${env.IMAGE_REGISTRY}/${IMAGE_NAME}:${env.FINAL_IMAGE_TAG}"

            echo "REG_HOST: ${env.REG_HOST}"
            echo "IMAGE_REF: ${env.IMAGE_REF}"
          }
        }
      }
    }

    // ── 4. 이미지 빌드 & 푸시 (Kaniko) ───────────────────────
    //      Kaniko: Dockerfile을 데몬 없이 빌드 (Docker socket 불필요)
    //      인증: /kaniko/.docker/config.json (registry-credentials Secret)
    stage('Image Build & Push (Kaniko)') {
      steps {
        container('kaniko') {
          dir("${env.WORKSPACE}") {
            sh '''
              /kaniko/executor \
                --dockerfile=Dockerfile \
                --context="${WORKSPACE}" \
                --destination="${IMAGE_REF}" \
                --force
            '''
            // 자체 서명 인증서를 사용하는 경우 아래 옵션 추가:
            // --skip-tls-verify-registry=${REG_HOST}
          }
        }
      }
    }

    // ── 5. k8s 매니페스트 이미지 태그 업데이트 ───────────────
    stage('Update K8s Manifests') {
      steps {
        container('maven') {
          dir("${env.WORKSPACE}") {
            sh '''
              set -eux
              test -f ./k8s/deploy.yaml

              echo "--- BEFORE ---"
              grep -n 'image:' ./k8s/deploy.yaml || true

              sed -Ei "s#(image:[[:space:]]*$IMAGE_REGISTRY/$IMAGE_NAME)[^[:space:]]+#\\1:$FINAL_IMAGE_TAG#" ./k8s/deploy.yaml

              echo "--- AFTER ---"
              grep -n 'image:' ./k8s/deploy.yaml || true
            '''
          }
        }
      }
    }

    // ── 6. Kubernetes 직접 배포 (kubectl apply) ───────────────
    //      에이전트 Pod가 jenkins ServiceAccount로 실행 → in-cluster 인증 자동 적용
    //      [주의] ClusterRole(jenkins-master)에 deployments 쓰기 권한 필요
    //             (01-rbac.yaml 업데이트 필요 - 파일 상단 주석 참조)
    stage('Deploy to Kubernetes') {
      steps {
        container('kubectl') {
          dir("${env.WORKSPACE}") {
            sh '''
              set -eux
              echo "=== k8s yaml 적용 ==="
              kubectl apply -n ${K8S_NAMESPACE} -f ./k8s/

              echo "=== 배포 롤아웃 대기 ==="
              kubectl rollout status deployment/${IMAGE_NAME} \
                -n ${K8S_NAMESPACE} \
                --timeout=180s

              echo "=== 배포 완료: ${IMAGE_REF} ==="
              kubectl get pods -n ${K8S_NAMESPACE} -l app=${IMAGE_NAME}
            '''
          }
        }
      }
    }

  } // stages

  post {
    success {
      echo "CI/CD 완료: ${env.IMAGE_REF} 이 ${K8S_NAMESPACE} 네임스페이스에 배포되었습니다."
    }
    failure {
      echo "파이프라인 실패. 로그를 확인하세요."
    }
  }
}
